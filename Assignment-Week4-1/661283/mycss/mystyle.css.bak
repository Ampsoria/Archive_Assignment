/* The element Selector */
body {
    background-color: lightblue;
}
h3 {
    color: navy;
    margin-left: 20px;
}
p {
    font-family: black;
    font-size: 30px;
    margin-left: 40px;
    color: Tomato;
}
div {
    background-color: black;
}
address {
    color: purple;
    font-size: 100%;
}

/* The id Selector */
#p1 {
    text-align: center;
    color: rgb(0,0,0);
}
#div1 {
    background-color: black;
}
#div2 {
    background-color: blue;
}
#div3 {
   background-color: green; 
}

/* The class Selector */
.p2 {
    background-color: #FFAADD;
    color: black;
}
.center {
    text-align: center;
    color: rgb(200,100,100);
}
.large {
    font-size: 50px;
}

/* Grouping Selector */
h1, h3 {
    color: blue;
    font-family: TH Sarabun New;
    font-size: 30px;
}